<input class="w-full px-4 py-2.5 pl-10 rounded-lg border border-[#e9f0f1] dark:border-white/10 bg-background-light dark:bg-background-dark focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" type="text" value="Senior Product Manager"/>
