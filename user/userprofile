<span class="material-symbols-outlined text-sm">verified</span> Verified
                                    </span>
</label>
<input class="w-full px-4 py-2.5 rounded-lg border border-[#e9f0f1] dark:border-white/10 bg-[#f1f4f5] dark:bg-white/5 text-[#5a878c] cursor-not-allowed" readonly="" type="email" value="john.doe@enterprise.com"/>
</div>
<div class="space-y-2">
<label class="text-xs font-bold text-[#5a878c] uppercase tracking-wider">Secondary Email</label>
