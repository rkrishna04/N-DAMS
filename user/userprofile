<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-primary">contact_mail</span>
<h2 class="text-lg font-bold">Contact Information</h2>
</div>
</div>
<div class="p-8 space-y-8">
<!-- Email Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6">
<div class="space-y-2">
<label class="text-xs font-bold text-[#5a878c] uppercase tracking-wider flex justify-between">
