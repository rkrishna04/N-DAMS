<input class="w-full px-4 py-2.5 rounded-lg border border-[#e9f0f1] dark:border-white/10 bg-background-light dark:bg-background-dark focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" type="text" value="John"/>
</div>
<div class="space-y-2">
<label class="text-xs font-bold text-[#5a878c] uppercase tracking-wider">Surname</label>
<input class="w-full px-4 py-2.5 rounded-lg border border-[#e9f0f1] dark:border-white/10 bg-background-light dark:bg-background-dark focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" type="text" value="Doe"/>
</div>
<div class="space-y-2 md:col-span-2">
